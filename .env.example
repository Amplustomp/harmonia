ICECAST_SOURCE_PASSWORD=change-me-source
ICECAST_RELAY_PASSWORD=change-me-relay
ICECAST_ADMIN_USERNAME=admin
ICECAST_ADMIN_PASSWORD=change-me-admin
ICECAST_ADMIN_EMAIL=admin@localhost
ICECAST_HOSTNAME=radio.admethius.quest
ICECAST_LOCATION=Home
ICECAST_MAX_CLIENTS=25
ICECAST_MAX_SOURCES=10

# Keep default local-only. Use 0.0.0.0 only when you want LAN access.
ICECAST_BIND=127.0.0.1
ICECAST_PORT=8000

# Library UI defaults to local-only for Cloudflare Tunnel. Docker cannot express
# "LAN-only" generically; use 0.0.0.0 only on a trusted LAN/firewall.
LIBRARY_BIND=127.0.0.1
LIBRARY_PORT=8091
STATS_REFRESH_SECONDS=60

# Local Cloudflare Tunnel credentials file. The JSON file is a secret; never commit it.
CLOUDFLARED_CREDENTIALS_FILE=/home/sergio/.cloudflared/203b947c-5c03-44f2-826b-bf0d02b8a8c3.json

# Yes, the directory is named mp3. It contains FLAC files. We live with shame.
MUSIC_DIR=/mnt/ssd-data/Music/mp3
